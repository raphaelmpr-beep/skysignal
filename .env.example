# Database
DATABASE_URL=postgresql://skysignal:skysignal@localhost:5432/skysignal
POSTGRES_USER=skysignal
POSTGRES_PASSWORD=skysignal
POSTGRES_DB=skysignal

# Auth
NEXTAUTH_SECRET=dev-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Maps
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_MAP_DEFAULT_LAT=39.8283
NEXT_PUBLIC_MAP_DEFAULT_LNG=-98.5795
NEXT_PUBLIC_MAP_DEFAULT_ZOOM=4

# API
NEXT_PUBLIC_API_URL=http://localhost:8000
API_SECRET_KEY=dev-api-secret

# Feature flags
ENABLE_GDELT=false
ENABLE_RSS_IMPORTER=false
ENABLE_FAA_IMPORTER=false
