# ============================================================
# SkySignal FastAPI — Environment Variables
# Copy to .env for local dev. Set these in Railway/Render.
# ============================================================

# --- Database (Supabase) ---
# Use the DIRECT connection (port 5432), NOT the pooler (6543)
# Find in: Supabase dashboard → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.fecaarqxtytaxkhmlngg.supabase.co:5432/postgres

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-strong-random-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Dev bypass (set to "true" to skip JWT auth — useful for demo/testing) ---
SKIP_AUTH=false

# --- Dev user IDs (used only when SKIP_AUTH=true) ---
DEV_ORG_ID=a0000000-0000-0000-0000-000000000001
DEV_USER_ID=00000000-0000-0000-0000-000000000002

# --- CORS (comma-separated list of allowed frontend origins) ---
ALLOWED_ORIGINS=https://skysignal.vercel.app,http://localhost:3000

# --- Geocoding (optional — Nominatim is free, no key needed) ---
GEOCODING_PROVIDER=nominatim

# --- GDELT / news ingestion (optional) ---
GDELT_ENABLED=false
